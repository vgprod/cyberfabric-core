{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.items.item.v1~x.llmgw.items.data_output.v1~",
  "title": "DataOutput",
  "description": "CyberFabric extension: binary data output item. Generic output item for binary data such as generated images, audio, or video.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "cyberfabric:data",
          "description": "Item type discriminator."
        },
        "id": {
          "type": "string",
          "description": "Unique item identifier."
        },
        "mime_type": {
          "type": "string",
          "description": "MIME type of the binary data (e.g., 'image/png', 'image/jpeg', 'audio/mp3')."
        },
        "base64": {
          "type": ["string", "null"],
          "description": "Base64-encoded binary data."
        },
        "url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "File storage URL for the binary data. "
        }
      },
      "required": ["type", "id", "status", "mime_type"]
    }
  ]
}
