{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gts://gtx.cf.chat_engine.common.session.v1~",
  "title": "Session",
  "description": "Chat session entity containing conversation context and metadata",
  "type": "object",
  "properties": {
    "session_id": {
      "$ref": "./GtsSessionId.json",
      "description": "Unique session identifier"
    },
    "tenant_id": {
      "$ref": "./GtsTenantId.json",
      "description": "Owning tenant (from JWT tenant_id claim)"
    },
    "user_id": {
      "$ref": "./GtsUserId.json",
      "description": "Owning user (from JWT user_id claim)"
    },
    "client_id": {
      "$ref": "./GtsClientId.json",
      "description": "Calling application identifier (from JWT client_id claim)"
    },
    "session_type_id": {
      "$ref": "./GtsSessionTypeId.json",
      "description": "Current session type reference"
    },
    "enabled_capabilities": {
      "type": "array",
      "items": { "$ref": "./Capability.json" },
      "description": "Capabilities confirmed and enabled by the backend plugin on session creation (`on_session_created`). Chat Engine uses this list for feature gating (e.g., file upload, summarization). May be a subset of `SessionType.available_capabilities` depending on plugin logic and `PluginConfig.config`."
    },
    "metadata": {
      "type": "object",
      "description": "Optional session metadata (title, tags, custom fields)",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Session creation timestamp",
      "examples": ["2024-01-15T10:30:00Z"]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last activity timestamp",
      "examples": ["2024-01-15T10:30:00Z"]
    },
    "share_token": {
      "type": ["string", "null"],
      "minLength": 32,
      "description": "Unique token for session sharing"
    },
    "lifecycle_state": {
      "$ref": "./LifecycleState.json",
      "description": "Current lifecycle state of the session"
    },
    "deleted_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Timestamp when session was soft-deleted"
    },
    "scheduled_hard_delete_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Timestamp when session will be permanently deleted"
    },
    "archived_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Timestamp when session was archived"
    },
    "memory_strategy": {
      "oneOf": [
        { "$ref": "./MemoryStrategy.json" },
        { "type": "null" }
      ],
      "description": "Conversation memory management strategy; null means default (full history). Controlled by feature-context-management (p2)."
    }
  },
  "required": ["session_id", "tenant_id", "user_id", "session_type_id", "enabled_capabilities", "lifecycle_state", "created_at", "updated_at"],
  "additionalProperties": false
}