{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gts://gts.cyberfabric.platform.entities.user_id.v1~",
  "title": "GTS User ID",
  "description": "GTS ID for a platform user entity (extracted from JWT user_id claim)",
  "type": "string",
  "pattern": "^gts\\.cyberfabric\\.platform\\.entities\\.user\\.v[0-9]+~[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
  "examples": [
    "gts.cyberfabric.platform.entities.user.v1~123e4567-e89b-12d3-a456-426614174000"
  ]
}