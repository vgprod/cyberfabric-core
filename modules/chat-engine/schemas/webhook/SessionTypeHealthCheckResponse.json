{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gts://gtx.cf.chat_engine.webhook.session_type_health_check_response.v1~",
  "title": "SessionTypeHealthCheckResponse",
  "description": "Webhook response with session type backend health status",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["healthy", "degraded", "unhealthy"],
      "description": "Backend health status"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Backend version",
      "examples": ["1.0.0"]
    },
    "available_capabilities": {
      "type": "array",
      "items": { "$ref": "../common/Capability.json" },
      "description": "Capabilities currently available for this session type"
    }
  },
  "required": ["status", "version", "available_capabilities"],
  "additionalProperties": false
}
