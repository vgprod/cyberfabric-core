{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gts://gtx.cf.core.events.event.v1~x.chat_engine.webhook.message_recreate_event.v1~",
  "title": "MessageRecreateEvent",
  "description": "Webhook event sent when a message regeneration is requested",
  "type": "object",
  "properties": {
    "event": {
      "type": "string",
      "const": "message.recreate",
      "description": "Event type identifier"
    },
    "session_id": {
      "$ref": "../common/GtsSessionId.json"
    },
    "message_id": {
      "$ref": "../common/GtsMessageId.json"
    },
    "enabled_capabilities": {
      "type": "array",
      "items": { "$ref": "../common/CapabilityValue.json" },
      "description": "Capability values active for this recreation"
    },
    "history": {
      "type": "array",
      "items": { "$ref": "../common/Message.json" },
      "description": "Message history up to the recreation point"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Event timestamp",
      "examples": ["2024-01-15T10:30:00Z"]
    }
  },
  "required": ["event", "session_id", "message_id", "history", "timestamp"],
  "additionalProperties": false
}
